# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/jobfinder?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# Email (Gmail)
