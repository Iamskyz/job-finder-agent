# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/jobfinder?retryWrites=true&w=majority

# JWT Secret
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this

# Email (Gmail)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_DEFAULT_SENDER=your_email@gmail.com

# App
FLASK_ENV=production
FRONTEND_URL=http://localhost:5173

# Cron security (set any random string, add same value in Vercel env vars)
CRON_SECRET=your-random-cron-secret

# Set to 1 only in Vercel dashboard, not locally
# VERCEL=1
